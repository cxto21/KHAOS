#!/bin/bash
# KHAOS — Show status
set -euo pipefail

echo "╔══════════════════════════════════════╗"
echo "║       KHAOS — Status                 ║"
echo "╚══════════════════════════════════════╝"
echo ""

check() {
  local name="$1" pidfile="$2"
  if [ -f "$pidfile" ] && kill -0 "$(cat "$pidfile")" 2>/dev/null; then
    echo "  ✅ $name (PID $(cat "$pidfile"))"
  else
    echo "  ❌ $name (not running)"
  fi
}

check "Xvfb"        /tmp/khaos/pids/xvfb.pid
check "Fluxbox"     /tmp/khaos/pids/fluxbox.pid
check "x11vnc"      /tmp/khaos/pids/x11vnc.pid
check "guacd"       /tmp/khaos/pids/guacd.pid
check "KHAOS daemon" /tmp/khaos/pids/daemon.pid
check "Dashboard"   /tmp/khaos/pids/api.pid
check "CF tunnel"   /tmp/khaos/pids/tunnel.pid

if pgrep -f "tomcat9" >/dev/null 2>&1; then
  echo "  ✅ Tomcat (running)"
else
  echo "  ❌ Tomcat (not running)"
fi

echo ""

if [ -f /tmp/khaos/logs/tunnel.log ]; then
  URL=$(grep -o 'https://[a-zA-Z0-9-]*\.trycloudflare\.com' /tmp/khaos/logs/tunnel.log 2>/dev/null | tail -1)
  if [ -n "$URL" ]; then
    echo "  Tunnel: ${URL}/guacamole"
  fi
fi

echo "  Local:  http://localhost:8080/guacamole"
echo "  VNC:    vnc://localhost:5900"
echo ""
