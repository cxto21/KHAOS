# KHAOS Configuration

# Guacamole web UI password
GUAC_PASSWORD=changeme

# VNC password
VNC_PASSWORD=changeme

# Screen resolution
SCREEN_RESOLUTION=1920x1080

# Color depth
COLOR_DEPTH=24

# KHAOS daemon port (Unix socket)
KHAOS_SOCKET=/tmp/khaos/khaos.sock

# MCP server port (TCP, for agent connections)
MCP_PORT=18789

# Dashboard port (if running standalone)
DASHBOARD_PORT=8090

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Agents to monitor (comma-separated)
KHAOS_AGENTS=claude,codex,opencode,gemini,cursor
